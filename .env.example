# Example backend environment variables
# Copy this to .env and adjust values for your local environment.

QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=tdr_documents
EMBEDDING_MODEL=ibm-granite/granite-embedding-97m-multilingual-r2

# ── LLM provider ────────────────────────────────────────────────
# Choose the model that generates answers: "ollama" (local) or "groq" (cloud).
# Switch by changing this line and restarting the backend.
LLM_PROVIDER=ollama

# Ollama (local) — used when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:latest

# Groq (cloud) — used when LLM_PROVIDER=groq. Get a free key at
# https://console.groq.com and paste it below.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

DEBUG_MODE=False

# Optional if you require a Qdrant API key
# QDRANT_API_KEY=
